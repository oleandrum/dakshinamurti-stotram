<!DOCTYPE html>
<html lang="{{ site.lang or 'en' }}">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{% if title %}{{ title }} — {% endif %}{{ site.title }}</title>
<meta name="description" content="{{ description or site.description }}">
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='14' fill='%231a1512'/%3E%3Crect x='1.5' y='1.5' width='61' height='61' rx='13' fill='none' stroke='%233d3324' stroke-width='2'/%3E%3Cg fill='none' stroke='%23c68a4c' stroke-width='3.4' stroke-linecap='round' stroke-linejoin='round'%3E%3Cpath d='M32 20.5c-4.4-3.2-9.8-4.3-15-4.3v27.6c5.2 0 10.6 1.1 15 4.3 4.4-3.2 9.8-4.3 15-4.3V16.2c-5.2 0-10.6 1.1-15 4.3Z'/%3E%3Cpath d='M32 20.5v27.6'/%3E%3C/g%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.bunny.net">
<link href="https://fonts.bunny.net/css?family=tiro-devanagari-sanskrit:400,400i|gentium-book-plus:400,400i,700|source-serif-4:400,500,600,400i|jetbrains-mono:400,500,600" rel="stylesheet">
<script>(function(){try{var t=localStorage.getItem('sds-theme');if(t==='light'||t==='dark'){document.documentElement.setAttribute('data-theme',t);}}catch(e){}})();</script>
<link rel="stylesheet" href="{{ '/assets/css/style.css' | url }}">
<meta name="theme-color" content="#1a1512">
</head>
<body>
<a class="skip-link" href="#main">Skip to content</a>

<header class="site-header">
  <div class="wrap site-header-inner">
    <a class="brand" href="{{ '/' | url }}">
      <span class="brand-mark" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M12 7.4c-1.7-1.3-3.8-1.8-5.7-1.8-.6 0-1.2 0-1.8.1v11.8c.6-.1 1.2-.1 1.8-.1 1.9 0 4 .5 5.7 1.8 1.7-1.3 3.8-1.8 5.7-1.8.6 0 1.2 0 1.8.1V5.7c-.6-.1-1.2-.1-1.8-.1-1.9 0-4 .5-5.7 1.8Z"/><path d="M12 7.4v11.8"/></svg></span>
      <span class="brand-text">{{ site.shortTitle or site.title }}</span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      <a href="{{ '/verses/' | url }}">Verses</a>
      <a href="{{ '/glossary/' | url }}">Glossary</a>
      <a href="{{ '/about/' | url }}">About</a>
      <a href="{{ '/transliteration-notes/' | url }}">Notes</a>
      <a href="{{ '/colophon/' | url }}">Colophon</a>
    </nav>

    <div class="theme-switch" role="group" aria-label="Theme">
      <button type="button" data-theme-choice="system" aria-label="System theme" aria-pressed="true">
        <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="13" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
      </button>
      <button type="button" data-theme-choice="light" aria-label="Light theme" aria-pressed="false">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="4.2"/><path d="M12 2.5v2.4M12 19.1v2.4M4.4 4.4l1.7 1.7M17.9 17.9l1.7 1.7M2.5 12h2.4M19.1 12h2.4M4.4 19.6l1.7-1.7M17.9 6.1l1.7-1.7"/></svg>
      </button>
      <button type="button" data-theme-choice="dark" aria-label="Dark theme" aria-pressed="false">
        <svg viewBox="0 0 24 24"><path d="M20 14.5A8.5 8.5 0 1 1 9.5 4a7 7 0 0 0 10.5 10.5Z"/></svg>
      </button>
    </div>
  </div>
</header>

<main id="main">
{{ content | safe }}
</main>

<footer class="site-footer">
  <div class="wrap">
    <nav class="footer-nav" aria-label="Footer">
      <a href="{{ '/verses/' | url }}">Verses</a>
      <a href="{{ '/glossary/' | url }}">Glossary</a>
      <a href="{{ '/about/' | url }}">About</a>
      <a href="{{ '/transliteration-notes/' | url }}">Transliteration notes</a>
      <a href="{{ '/colophon/' | url }}">Colophon</a>
      <a href="{{ '/license/' | url }}">License</a>
    </nav>

    <div class="footer-downloads">
      <a class="download-btn" href="{{ ('/downloads/' ~ site.slug ~ '.pdf') | url }}" download>
        <svg viewBox="0 0 24 24"><path d="M12 4v12m0 0l-4-4m4 4l4-4M5 20h14"/></svg>
        PDF
      </a>
      <a class="download-btn" href="{{ ('/downloads/' ~ site.slug ~ '.epub') | url }}" download>
        <svg viewBox="0 0 24 24"><path d="M12 4v12m0 0l-4-4m4 4l4-4M5 20h14"/></svg>
        EPUB
      </a>
      <a class="download-btn" href="{{ site.repo }}" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.5c0-1 .1-1.4-.5-2 2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 0 0-1.3-3.2 4.2 4.2 0 0 0-.1-3.2s-1.1-.3-3.5 1.3a12.3 12.3 0 0 0-6.2 0C7.5 2.3 6.4 2.6 6.4 2.6a4.2 4.2 0 0 0-.1 3.2A4.6 4.6 0 0 0 5 9c0 4.6 2.7 5.7 5.5 6-.6.6-.6 1.2-.5 2V21"/></svg>
        Source
      </a>
    </div>

    <p class="footer-note">{{ site.footerNote or "" }}</p>
    <p class="footer-note">Translation &amp; notes: <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/" rel="license noopener" target="_blank">CC BY-NC-SA 4.0</a> · Site code: <a href="{{ '/license/' | url }}">MIT</a></p>
  </div>
</footer>

<script src="{{ '/assets/js/theme.js' | url }}"></script>
<script src="{{ '/assets/js/toggle.js' | url }}"></script>
</body>
</html>
